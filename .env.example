# Backend API base URL. Inlined into the client bundle at build time.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8787/api/v1

# Backend WebSocket base URL. Used by src/lib/ws-client.ts.
NEXT_PUBLIC_WS_BASE=ws://127.0.0.1:8787/api/v1

# Build-time git SHA, surfaced on the /about debug page (optional).
# NEXT_PUBLIC_BUILD_SHA=

# Never put credentials or tokens in NEXT_PUBLIC_* — they ship to the browser.
# The dashboard is read-only and the current API has no auth.
